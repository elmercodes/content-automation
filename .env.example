# Copy this file to .env before running the app.
# The workflow is local-only: SQLite, uploads, generated previews, and connected
# account tokens all stay on the local machine.

# Core application settings
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_BASE_URL=https://localhost:8000
DATABASE_URL=sqlite:///./storage/db/app.db
STORAGE_ROOT=storage
UPLOADS_DIR=storage/uploads
GENERATED_DIR=storage/generated

# Provider app configuration
# - Leave values empty to disable OAuth connect flows for a provider.
# - These settings are for provider app registration only.
# - User account authorization now happens through the Accounts page and is
#   stored locally in SQLite after the OAuth flow completes.

# Instagram professional-account login
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=

# Facebook login plus managed Page selection
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# Meta Graph API version used for Facebook login and page lookup
META_API_VERSION=v23.0

# X OAuth 2.0 with PKCE
# X_CLIENT_ID=
