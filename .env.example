# Core application settings
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite:///./storage/db/app.db
STORAGE_ROOT=storage
UPLOADS_DIR=storage/uploads
GENERATED_DIR=storage/generated

# Platform visibility in Phase 3 is local-only and settings-driven.
# Add only the platforms you intend to enable on this machine.

# Instagram
# INSTAGRAM_ACCESS_TOKEN=

# Facebook
# FACEBOOK_PAGE_ID=

# X
# X_API_KEY=
