# Copy this file to .env before running the app.
# The workflow is local-only: SQLite, uploads, and generated previews all stay
# on the local machine.

# Core application settings
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite:///./storage/db/app.db
STORAGE_ROOT=storage
UPLOADS_DIR=storage/uploads
GENERATED_DIR=storage/generated

# Provider setup notes
# - Leave values empty to keep a platform hidden in the workflow.
# - Instagram and Facebook become visible for review when configured, but direct
#   posting is still deferred in the current product.
# - X becomes visible with X_API_KEY alone.
# - X direct posting additionally requires X_API_SECRET, X_ACCESS_TOKEN, and
#   X_ACCESS_TOKEN_SECRET.

# Instagram: visible in the workflow only
# INSTAGRAM_ACCESS_TOKEN=

# Facebook: visible in the workflow only
# FACEBOOK_PAGE_ID=

# X: visible with X_API_KEY, directly postable only with all four X fields
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
